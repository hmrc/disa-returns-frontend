uploadFile.rejected = The file you uploaded is not recognised. The selected file must be in CSV or Excel format
uploadFile.invalidArgument = Select a file that you want to submit as your monthly report
uploadFile.failed = There was a problem uploading your file

fileUploadFailed.title = The selected file could not be uploaded
fileUploadFailed.heading = The selected file could not be uploaded
fileUploadFailed.p1 = There was a problem uploading the selected file - try again.
